---
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: '首页' },
  { href: '/knowledge/', label: '知识库' },
  { href: '/lessons/', label: '教学日记' },
];
---

<header class:list={[
  "fixed top-0 left-0 right-0 z-50 transition-colors duration-300",
  isHome
    ? "bg-court-surround/95 backdrop-blur-sm border-b border-white/10"
    : "bg-white border-b border-paper-dark",
]}>
  <nav class="max-w-6xl mx-auto px-(--spacing-page) flex items-center justify-between h-16">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5 group">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" class:list={[
        "transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-12",
        isHome ? "text-white" : "text-court",
      ]}>
        <circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M12 13 L12 28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M7 19 L17 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class:list={["font-display text-xl", isHome ? "text-white" : "text-ink"]}>
        Shuttle Path
      </span>
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-10">
      {links.map((link) => {
        const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
        return (
          <a
            href={link.href}
            class:list={[
              'nav-link text-sm font-medium tracking-wide transition-colors duration-200',
              isHome
                ? (isActive ? 'text-white active' : 'text-white/70 hover:text-white')
                : (isActive ? 'text-court active' : 'text-ink-light hover:text-court'),
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class:list={[
        "md:hidden p-2 -mr-2 transition-colors",
        isHome ? "text-white/70 hover:text-white" : "text-ink-light hover:text-court",
      ]}
      aria-label="打开菜单"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" class="origin-center transition-transform duration-300" id="menu-line-1"/>
        <line x1="3" y1="12" x2="21" y2="12" class="transition-opacity duration-300" id="menu-line-2"/>
        <line x1="3" y1="18" x2="21" y2="18" class="origin-center transition-transform duration-300" id="menu-line-3"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-400 ease-[--ease-out-expo]"
    style="max-height: 0;"
  >
    <div class:list={[
      "px-(--spacing-page) pb-6 pt-2 flex flex-col gap-1 border-t",
      isHome ? "border-white/10" : "border-paper-dark",
    ]}>
      {links.map((link) => {
        const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href));
        return (
          <a
            href={link.href}
            class:list={[
              'squircle block py-3 px-4 rounded-xl text-sm font-medium transition-colors duration-200',
              isHome
                ? (isActive ? 'text-white bg-white/15' : 'text-white/70 hover:text-white hover:bg-white/10')
                : (isActive ? 'text-court bg-court-50' : 'text-ink-light hover:text-court hover:bg-court-50/50'),
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    if (menu) {
      menu.style.maxHeight = open ? `${menu.scrollHeight}px` : '0';
    }
    btn.setAttribute('aria-label', open ? '关闭菜单' : '打开菜单');

    const l1 = document.getElementById('menu-line-1');
    const l2 = document.getElementById('menu-line-2');
    const l3 = document.getElementById('menu-line-3');
    if (open) {
      l1?.setAttribute('transform', 'rotate(45 12 12)');
      l2?.setAttribute('style', 'opacity:0');
      l3?.setAttribute('transform', 'rotate(-45 12 12)');
    } else {
      l1?.removeAttribute('transform');
      l2?.removeAttribute('style');
      l3?.removeAttribute('transform');
    }
  });
</script>
