---
import Nav from '@/components/common/Nav.astro';
import Footer from '@/components/common/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '羽毛球教学知识平台 —— 手法、步法、运动科学' } = Astro.props;
const fullTitle = title === '首页' ? 'Shuttle Path — 羽毛球教学知识平台' : `${title} | Shuttle Path`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700;900&family=ZCOOL+QingKe+HuangYou&display=swap" rel="stylesheet" />
    <link rel="preload" href="/fonts/SmileySans-Oblique-subset.woff2" as="font" type="font/woff2" crossorigin />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Global SVG filters (手绘毛边效果) -->
    <svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position:absolute">
      <defs>
        <filter id="squiggle-filter">
          <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="4" seed="1" />
          <feDisplacementMap in="SourceGraphic" scale="3" />
        </filter>
      </defs>
    </svg>
    <Nav />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />

    <!-- Scroll-triggered fade-in -->
    <script>
      function initFadeIn() {
        const els = document.querySelectorAll('.fade-in-up');
        if (!els.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
        );

        els.forEach((el) => {
          // Elements already in viewport: show immediately without transition delay
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add('is-visible');
          } else {
            observer.observe(el);
          }
        });
      }

      initFadeIn();
      document.addEventListener('astro:page-load', initFadeIn);
    </script>
  </body>
</html>
