---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const sorted = allLessons.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const accentColors = ['#10B981', '#F59E0B', '#FB7185', '#3B82F6', '#8B5CF6'];

const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="教学日记" description="羽毛球教学课堂记录与反思">
  <div class="max-w-6xl mx-auto px-(--spacing-page) py-10 md:py-20">
    <!-- Header -->
    <div class="mb-10 md:mb-14">
      <h1 class="heading-display text-ink mb-3 fade-in-up">
        教学日记
      </h1>
      <p class="text-xs uppercase tracking-[0.2em] text-shuttle font-medium mb-3 md:mb-4 fade-in-up" style="transition-delay:80ms">
        Lessons
      </p>
      <p class="text-sm md:text-base text-ink-muted max-w-lg leading-relaxed fade-in-up" style="transition-delay:160ms">
        每一节课都是一次独立的创作。这里记录教学过程、训练思路与课后反思。
      </p>
    </div>

    {sorted.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 stagger-children">
        {sorted.map((lesson, i) => {
          const accentColor = lesson.data.coverColor || accentColors[i % accentColors.length];
          return (
            <a
              href={`/lessons/${lesson.id}/`}
              class="fade-in-up card-tilted squircle group block rounded-2xl overflow-hidden border border-paper-dark bg-white transition-all duration-300"
            >
              <div class="flex">
                {/* 左侧彩色竖条 */}
                <div
                  class="w-1.5 flex-shrink-0 rounded-l-2xl"
                  style={`background-color: ${accentColor}`}
                />
                <div class="p-6 flex-1">
                  <time class="text-xs text-ink-muted">{formatDate(lesson.data.date)}</time>
                  <h3 class="text-lg font-bold text-ink mt-1.5 mb-2 group-hover:text-court transition-colors leading-snug">
                    {lesson.data.title}
                  </h3>
                  {lesson.data.description && (
                    <p class="text-sm text-ink-muted leading-relaxed line-clamp-3">
                      {lesson.data.description}
                    </p>
                  )}
                  {lesson.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                      {lesson.data.tags.map((tag: string) => (
                        <span class="text-xs text-ink-muted border-b border-dashed border-ink-muted/30">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20 fade-in-up">
        {/* 空状态占位 — 等手绘插画交付后替换 */}
        <div class="w-20 h-20 rounded-full bg-paper-dark flex items-center justify-center mx-auto mb-5">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" class="text-ink-muted">
            <rect x="4" y="3" width="16" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <line x1="8" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="8" y1="12" x2="14" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="8" y1="16" x2="12" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <p class="text-ink-muted font-medium mb-1">教学日记即将开始</p>
        <p class="text-sm text-ink-muted/60">第一节课正在筹备中...</p>
      </div>
    )}
  </div>
</BaseLayout>
