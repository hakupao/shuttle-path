---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allKnowledge = await getCollection('knowledge', ({ data }) => !data.draft);
const allLessons = await getCollection('lessons', ({ data }) => !data.draft);

const recentLessons = allLessons
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const knowledgeCats = [
  {
    key: 'strokes',
    label: '手法',
    en: 'Strokes',
    description: '握拍、发球、后场、前场、中场技术',
    count: allKnowledge.filter((a) => a.data.category === 'strokes').length,
  },
  {
    key: 'footwork',
    label: '步法',
    en: 'Footwork',
    description: '站位、启动、上网、后退、全场串联',
    count: allKnowledge.filter((a) => a.data.category === 'footwork').length,
  },
  {
    key: 'sports-science',
    label: '运动科学',
    en: 'Science',
    description: '热身放松、发力原理、体能训练、伤病预防',
    count: allKnowledge.filter((a) => a.data.category === 'sports-science').length,
  },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="首页" isHome>
  <div class="scene">
    <div class="camera" id="camera">
      <div class="camera-rig" id="camera-rig">
  <div class="court-outer">
    <div class="court" role="main">
      {/* 右侧单打边线 */}
      <div class="singles-line-right"></div>

      {/* 场地灯光 */}
      <div class="court-vignette" aria-hidden="true"></div>
      <div id="spotlight" class="spotlight" aria-hidden="true"></div>

      {/* 羽毛球飞行动画 */}
      <div id="shuttle" class="shuttle" aria-hidden="true">
        <div class="shuttle-shadow"></div>
        <svg class="shuttle-svg" viewBox="0 0 36 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          {/* 羽毛 — 5根辐射线 */}
          <line x1="18" y1="28" x2="6" y2="4" stroke="white" stroke-width="1.5" stroke-linecap="round" />
          <line x1="18" y1="28" x2="12" y2="2" stroke="white" stroke-width="1.5" stroke-linecap="round" />
          <line x1="18" y1="28" x2="18" y2="1" stroke="white" stroke-width="1.5" stroke-linecap="round" />
          <line x1="18" y1="28" x2="24" y2="2" stroke="white" stroke-width="1.5" stroke-linecap="round" />
          <line x1="18" y1="28" x2="30" y2="4" stroke="white" stroke-width="1.5" stroke-linecap="round" />
          {/* 羽毛轮廓弧线 */}
          <path d="M6,4 Q12,0 18,1 Q24,0 30,4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" />
          {/* 羽毛根部绑线 */}
          <ellipse cx="18" cy="28" rx="6" ry="2" stroke="white" stroke-width="1.2" fill="none" />
          {/* 球托：暗描边 + 白填充，避免撞场地白线 */}
          <circle cx="18" cy="38" r="6" stroke="rgba(0,0,0,0.55)" stroke-width="1" fill="none" />
          <circle cx="18" cy="38" r="5" stroke="white" stroke-width="1.5" fill="white" fill-opacity="0.3" />
        </svg>
      </div>

      {/* ======================================================
          上半场
          ====================================================== */}

      {/* --- 后发球线区域（两个小格子） --- */}
      <div class="court-row court-row-back-service">
        <div class="court-half court-half-left"></div>
        <div class="court-half court-half-right"></div>
      </div>

      {/* --- Hero 后场区 --- */}
      <div class="court-row court-row-hero">
        {/* 中线渐隐：从底部前发球线处纯白 → 向上渐隐消失 */}
        <div class="hero-center-line"></div>
        <div class="court-pad relative z-[1]">
          <h1 class="font-display text-2xl md:text-4xl text-white leading-tight mb-3 holo-text" data-focus-anchor>
            Shuttle Path
          </h1>
          <p class="text-sm md:text-base text-white/80 leading-relaxed mb-1">
            羽毛球教学知识平台
          </p>
          <p class="text-xs md:text-sm text-white/50 leading-relaxed mb-6 max-w-[280px]">
            从握拍到杀球，从站位到全场步法——系统化的羽毛球知识库与教学日记。
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/knowledge/" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/15 text-white text-xs font-medium rounded-lg border border-white/25 hover:bg-white/25 transition-colors">
              浏览知识库
            </a>
            <a href="/lessons/" class="inline-flex items-center gap-1.5 px-4 py-2 text-white/70 text-xs font-medium rounded-lg border border-white/15 hover:text-white hover:border-white/30 transition-colors">
              教学日记
            </a>
          </div>
        </div>
      </div>

      {/* --- 前发球线（分隔） --- */}
      <div class="court-line-h"></div>

      {/* --- 涨球记录（原教学日记）— 全宽 --- */}
      <a href="/lessons/" class="court-row court-row-lessons group">
        <div class="court-pad">
          <h2 class="text-lg md:text-xl text-white font-bold mb-2 group-hover:text-white/80 transition-colors holo-text" data-focus-anchor>
            涨球记录
          </h2>
          <p class="text-xs text-white/40 mb-3">原教学日记</p>
          {recentLessons.length > 0 ? (
            <div class="space-y-2">
              {recentLessons.map((lesson) => (
                <div class="flex items-baseline gap-3">
                  <time class="text-[10px] text-white/35 flex-shrink-0 tabular-nums">{formatDate(lesson.data.date)}</time>
                  <span class="text-xs text-white/70">{lesson.data.title}</span>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-xs text-white/40">即将更新</p>
          )}
        </div>
      </a>

      {/* ======================================================
          球网 NET
          ====================================================== */}
      <div class="court-net"><span class="court-net-label">NET</span></div>

      {/* ======================================================
          下半场
          ====================================================== */}

      {/* --- 知识库 — 全宽 --- */}
      <a href="/knowledge/" class="court-row court-row-knowledge group">
        <div class="court-pad">
          <h2 class="text-lg md:text-xl text-white font-bold mb-1 group-hover:text-white/80 transition-colors holo-text" data-focus-anchor>
            知识库
          </h2>
          <p class="text-xs text-white/40 mb-3">Knowledge Base</p>
          <p class="text-xs text-white/55 leading-relaxed">
            系统化的羽毛球技术知识，从基础握拍到高级战术，从步法启动到运动科学。
          </p>
          <span class="inline-block mt-3 text-[11px] text-white/40 border border-white/15 rounded px-2 py-0.5">
            {allKnowledge.length} 篇文章
          </span>
        </div>
      </a>

      {/* --- 前发球线（分隔） --- */}
      <div class="court-line-h"></div>

      {/* --- 手法 | 步法 — 中线分割 --- */}
      <div class="court-row court-row-cats">
        <a href={`/knowledge/?category=strokes`} class="court-half court-half-left court-cat group">
          <div class="court-pad-left" data-focus-anchor>
            <h3 class="text-base md:text-lg text-white font-bold mb-1 group-hover:text-white/80 transition-colors holo-text">
              {knowledgeCats[0].label}
            </h3>
            <p class="text-[10px] text-white/35 uppercase tracking-wider mb-2">{knowledgeCats[0].en}</p>
            <p class="text-xs text-white/50 leading-relaxed mb-2">{knowledgeCats[0].description}</p>
            <span class="text-[10px] text-white/35">
              {knowledgeCats[0].count > 0 ? `${knowledgeCats[0].count} 篇` : '即将更新'}
            </span>
          </div>
        </a>
        <a href={`/knowledge/?category=footwork`} class="court-half court-half-right court-cat group">
          <div class="court-pad-right">
            <h3 class="text-base md:text-lg text-white font-bold mb-1 group-hover:text-white/80 transition-colors holo-text">
              {knowledgeCats[1].label}
            </h3>
            <p class="text-[10px] text-white/35 uppercase tracking-wider mb-2">{knowledgeCats[1].en}</p>
            <p class="text-xs text-white/50 leading-relaxed mb-2">{knowledgeCats[1].description}</p>
            <span class="text-[10px] text-white/35">
              {knowledgeCats[1].count > 0 ? `${knowledgeCats[1].count} 篇` : '即将更新'}
            </span>
          </div>
        </a>
      </div>

      {/* --- 底部其他（后发球线区域） --- */}
      <div class="court-row court-row-footer">
        <a href={`/knowledge/?category=sports-science`} class="court-half court-half-left court-cat group">
          <div class="court-pad-left-sm" data-focus-anchor>
            <h3 class="text-sm text-white font-bold group-hover:text-white/80 transition-colors holo-text">{knowledgeCats[2].label}</h3>
            <p class="text-[10px] text-white/35 mt-0.5">{knowledgeCats[2].en}</p>
          </div>
        </a>
        <div class="court-half court-half-right">
          <div class="court-pad-right-sm">
            <p class="text-[10px] text-white/30 text-right">
              &copy; Shuttle Path
            </p>
          </div>
        </div>
      </div>

    </div>

    {/* 球场尺寸标注 */}
    <div class="court-dims">
      <span class="court-dim-w">6.10m</span>
      <span class="court-dim-h">13.40m</span>
    </div>
  </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ============================================
     场地灯光效果
     - .court box-shadow：场外溢出（见 .court 规则）
     - .court-vignette：场内顶灯（左3右3）+ 四角暗角
     - .spotlight：追踪射灯（跟随羽毛球）
     ============================================ */

  /* 场内顶灯 + 暗角 */
  .court-vignette {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      /* 左侧3盏灯 — 1/r² 衰减 */
      radial-gradient(ellipse 55% 18% at 28% 18%,
        rgba(255,255,255,0.14) 0%, rgba(255,255,255,0.08) 15%,
        rgba(255,255,255,0.03) 35%, rgba(255,255,255,0.008) 60%, transparent 100%),
      radial-gradient(ellipse 55% 18% at 26% 50%,
        rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.09) 15%,
        rgba(255,255,255,0.03) 35%, rgba(255,255,255,0.008) 60%, transparent 100%),
      radial-gradient(ellipse 55% 18% at 28% 82%,
        rgba(255,255,255,0.14) 0%, rgba(255,255,255,0.08) 15%,
        rgba(255,255,255,0.03) 35%, rgba(255,255,255,0.008) 60%, transparent 100%),
      /* 右侧3盏灯 */
      radial-gradient(ellipse 55% 18% at 72% 18%,
        rgba(255,255,255,0.14) 0%, rgba(255,255,255,0.08) 15%,
        rgba(255,255,255,0.03) 35%, rgba(255,255,255,0.008) 60%, transparent 100%),
      radial-gradient(ellipse 55% 18% at 74% 50%,
        rgba(255,255,255,0.15) 0%, rgba(255,255,255,0.09) 15%,
        rgba(255,255,255,0.03) 35%, rgba(255,255,255,0.008) 60%, transparent 100%),
      radial-gradient(ellipse 55% 18% at 72% 82%,
        rgba(255,255,255,0.14) 0%, rgba(255,255,255,0.08) 15%,
        rgba(255,255,255,0.03) 35%, rgba(255,255,255,0.008) 60%, transparent 100%),
      /* 整体暗角 — 四角压暗，1/r² 从中心往外 */
      radial-gradient(ellipse 80% 60% at 50% 50%,
        transparent 20%, rgba(0,0,0,0.10) 40%,
        rgba(0,0,0,0.25) 65%, rgba(0,0,0,0.40) 100%);
  }

  /* 追踪射灯 — 1/r² 衰减的聚光 */
  .spotlight {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    width: 140px;
    height: 140px;
    top: 0;
    left: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      rgba(255, 255, 255, 0.28) 0%,
      rgba(255, 255, 255, 0.15) 15%,
      rgba(255, 255, 255, 0.05) 35%,
      rgba(255, 255, 255, 0.01) 55%,
      transparent 80%
    );
    opacity: 0;
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  @media (min-width: 768px) {
    .spotlight {
      width: 200px;
      height: 200px;
    }
  }

  /* 无障碍 */
  @media (prefers-reduced-motion: reduce) {
    .spotlight {
      display: none !important;
    }
  }

  /* ============================================
     羽毛球飞行动画
     ============================================ */
  .shuttle {
    position: absolute;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    width: 32px;
    height: 48px;
    top: 0;
    left: 0;
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  @media (min-width: 768px) {
    .shuttle {
      width: 40px;
      height: 60px;
    }
  }

  .shuttle-svg {
    width: 100%;
    height: 100%;
  }

  .shuttle-shadow {
    position: absolute;
    bottom: -10px;
    left: 50%;
    width: 28px;
    height: 12px;
    transform: translateX(-50%) translateZ(0);
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.3) 0%, transparent 70%);
    border-radius: 50%;
    will-change: transform, opacity;
  }

  .shuttle.is-active {
    opacity: 1;
  }

  /* 无障碍：减少动画 */
  @media (prefers-reduced-motion: reduce) {
    .shuttle {
      display: none !important;
    }
  }

  /* ============================================
     Zone 1: 场外暗化 — 模拟体育馆场外黑暗
     ============================================ */
  :global(body.bg-court-surround) {
    --color-court-surround: #061a10;
  }

  /* ============================================
     3D 摄像机系统 — 三层包装
     scene: 滚动空间 → camera: 透视投影 → camera-rig: 3D 变换
     ============================================ */

  /* 滚动空间容器 */
  .scene {
    height: 500vh;
    position: relative;
  }

  /* 摄像机 — 提供 CSS perspective，用 sticky 固定（避免 JS pin 抖动） */
  .camera {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 800px;
    perspective-origin: 50% 50%;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .camera {
      perspective: 1200px;
      perspective-origin: 50% 50%;
    }
  }

  /* 摄像机云台 — GSAP 动画目标 */
  .camera-rig {
    transform-style: preserve-3d;
    transform: rotateX(18deg) scale(0.6);
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  @media (min-width: 768px) {
    .camera-rig {
      transform: rotateX(22deg) scale(0.7);
    }
  }

  /* 无障碍：减少动画时回退为平面布局 */
  @media (prefers-reduced-motion: reduce) {
    .scene {
      height: auto;
    }
    .camera {
      position: static;
      height: auto;
      perspective: none;
    }
    .camera-rig {
      transform: none;
      transform-style: flat;
    }
  }

  /* ============================================
     球场容器 — 竖向细长，居中
     真实比例 13.4:6.1 ≈ 2.2:1
     ============================================ */
  .court-outer {
    position: relative;
    max-width: 480px;
    margin: 0 auto;
    padding: 0 16px;
  }

  @media (min-width: 768px) {
    .court-outer {
      max-width: 520px;
    }
  }

  /* 球场主体 */
  .court {
    background: var(--color-court);
    border: 4px solid white;
    border-radius: 2px;
    position: relative;
    /* overflow: hidden 已移除 — 与 preserve-3d 冲突 */
    transform-style: preserve-3d;
    /* 灯光溢出 — 两层足够，避免 3D 放大时阴影膨胀失控 */
    box-shadow:
      0 0 40px 8px rgba(27, 138, 78, 0.25),
      0 0 90px 24px rgba(27, 138, 78, 0.10);
  }

  /* 噪点纹理 */
  .court::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='2.5' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    z-index: 0;
  }

  /* 单打边线 — 左 */
  .court::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 7.5%;
    width: 4px;
    background: white;
    z-index: 2;
    pointer-events: none;
  }

  /* 单打边线 — 右 */
  .singles-line-right {
    position: absolute;
    top: 0; bottom: 0;
    right: 7.5%;
    width: 4px;
    background: white;
    z-index: 2;
    pointer-events: none;
  }

  /* ============================================
     内容 padding — 确保文字在单打边线内侧
     单打边线在 7.5%，内容从 11% 开始（留白）
     ============================================ */
  /* 全宽区域 padding（在单打边线内侧） */
  .court-pad {
    padding: 16px 12%;
  }
  @media (min-width: 768px) {
    .court-pad {
      padding: 28px 12%;
    }
  }

  /* 半场格子 padding（左半场靠左边线，右半场靠右边线） */
  .court-pad-left {
    padding: 14px 8px 14px 19%;
  }
  .court-pad-right {
    padding: 14px 19% 14px 8px;
  }
  .court-pad-left-sm {
    padding: 10px 8px 10px 19%;
  }
  .court-pad-right-sm {
    padding: 10px 19% 10px 8px;
  }
  @media (min-width: 768px) {
    .court-pad-left {
      padding: 28px 14px 28px 19%;
    }
    .court-pad-right {
      padding: 28px 19% 28px 14px;
    }
    .court-pad-left-sm {
      padding: 16px 14px 16px 19%;
    }
    .court-pad-right-sm {
      padding: 16px 19% 16px 14px;
    }
  }

  /* ============================================
     行（Row）— 球场区域
     ============================================ */
  .court-row {
    position: relative;
    z-index: 1;
    transform: translateZ(30px);
  }

  /* ============================================
     后发球线区域 — 顶部/底部小窄条
     ============================================ */
  .court-row-back-service {
    display: flex;
    height: 28px;
    border-bottom: 4px solid white;
  }
  @media (min-width: 768px) {
    .court-row-back-service {
      height: 40px;
    }
  }

  /* ============================================
     Hero 后场区
     ============================================ */
  .court-row-hero {
    border-bottom: none; /* 下面由 court-line-h 处理 */
    min-height: 280px;
    display: flex;
    align-items: center;
  }
  @media (min-width: 768px) {
    .court-row-hero {
      min-height: 360px;
    }
  }

  /* Hero 中线渐隐（从底部实线 → 向上消失） */
  .hero-center-line {
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 4px;
    height: 100%;
    transform: translateX(-50%);
    background: linear-gradient(to top, white 0%, white 5%, transparent 60%);
    z-index: 0;
    pointer-events: none;
  }

  /* ============================================
     涨球记录 / 知识库
     ============================================ */
  .court-row-lessons,
  .court-row-knowledge {
    display: block;
    text-decoration: none;
    color: white;
    border-bottom: none;
    min-height: 140px;
  }
  @media (min-width: 768px) {
    .court-row-lessons { min-height: 180px; }
    .court-row-knowledge { min-height: 180px; }
  }

  /* ============================================
     手法 | 步法 — 中线分割区域
     ============================================ */
  .court-row-cats {
    display: flex;
    flex-direction: row;
    /* 不需要 border-top，上面的 .court-line-h 已经是前发球线 */
  }
  @media (min-width: 768px) {
    .court-row-cats {
      min-height: 280px;
    }
  }

  /* ============================================
     底部行
     ============================================ */
  .court-row-footer {
    display: flex;
    flex-direction: row;
    border-top: 4px solid white;
  }
  @media (min-width: 768px) {
    .court-row-footer {
      min-height: 48px;
    }
  }

  /* ============================================
     半场单元格（左 | 右）
     ============================================ */
  .court-half {
    flex: 1;
  }
  .court-half-left {
    border-right: 4px solid white;
  }

  .court-cat {
    display: block;
    text-decoration: none;
    color: white;
  }

  /* ============================================
     水平分隔线 — 前发球线
     ============================================ */
  .court-line-h {
    height: 4px;
    background: white;
    position: relative;
    z-index: 2;
    margin-left: 7.5%;
    margin-right: 7.5%;
  }

  /* ============================================
     球网 NET — 粗线 + 中心圆点
     ============================================ */
  .court-net {
    height: 4px;
    background: white;
    position: relative;
    z-index: 3;
  }

  .court-net-label {
    position: absolute;
    right: -24px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 9px;
    color: rgba(255, 255, 255, 0.3);
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    pointer-events: none;
  }

  /* ============================================
     球场尺寸标注（场外文字）
     ============================================ */
  .court-dims {
    pointer-events: none;
    position: absolute;
    inset: 0;
  }
  .court-dim-w {
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: rgba(255, 255, 255, 0.3);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }
  .court-dim-h {
    position: absolute;
    left: -20px;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    font-size: 10px;
    color: rgba(255, 255, 255, 0.3);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }
</style>

<script>
  // ============================================
  // 滚动动画 — 3D 转播视角 + 镜头升降
  // CSS sticky 固定视口，GSAP ScrollTrigger 驱动动画
  // 所有位移使用 transform（y/x），避免 Layout Reflow
  // ============================================
  (function initCameraAnimation() {
    const shuttle = document.getElementById('shuttle');
    const courtEl = document.querySelector('.court') as HTMLElement | null;
    const cameraRig = document.getElementById('camera-rig');
    const sceneEl = document.querySelector('.scene') as HTMLElement | null;
    if (!shuttle || !courtEl || !cameraRig || !sceneEl) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const rows = {
      hero: courtEl.querySelector('.court-row-hero') as HTMLElement,
      lessons: courtEl.querySelector('.court-row-lessons') as HTMLElement,
      knowledge: courtEl.querySelector('.court-row-knowledge') as HTMLElement,
      cats: courtEl.querySelector('.court-row-cats') as HTMLElement,
      footer: courtEl.querySelector('.court-row-footer') as HTMLElement,
    };

    function centerY(el: HTMLElement) { return el.offsetTop + el.offsetHeight / 2; }

    // section 的视觉聚焦点在 camera-rig 中的 Y 坐标
    // 优先读取 [data-focus-anchor] 元素中心；fallback 用 section 顶部 20%
    function getSectionFocusPoint(section: HTMLElement) {
      const anchor = section.querySelector('[data-focus-anchor]') as HTMLElement | null;
      const target = anchor || section;
      let top = 0;
      let el: HTMLElement | null = target;
      while (el && el !== cameraRig) {
        top += el.offsetTop;
        el = el.offsetParent as HTMLElement | null;
      }
      return anchor
        ? top + anchor.offsetHeight / 2
        : top + section.offsetHeight * 0.50;
    }

    function getSectionOffsetY(section: HTMLElement) {
      const rigH = cameraRig!.offsetHeight;
      const focusPoint = getSectionFocusPoint(section);
      return -(focusPoint - rigH / 2);
    }

    // 把 3D 变换后 anchor 的屏幕位置精确对齐到摄像机视口中心
    // 2D 公式（getSectionOffsetY）得到的 ty 忽略了 rotateX 的透视投影，
    // 导致顶部/底部 section 的 anchor 视觉上偏离视口中心。
    // 这里通过迭代试探：应用临时 transform → 测量 anchor 屏幕中心 → 调整 ty。
    function calibrateFocusTy(section: HTMLElement, fScale: number, fAngle: number, gsap: any): number {
      const anchor = (section.querySelector('[data-focus-anchor]') as HTMLElement | null) || section;
      const cameraEl = document.getElementById('camera');
      if (!cameraEl) return getSectionOffsetY(section);
      let ty = getSectionOffsetY(section);
      for (let i = 0; i < 6; i++) {
        gsap.set(cameraRig, { rotateX: fAngle, scale: fScale, y: ty, force3D: true });
        const camRect = cameraEl.getBoundingClientRect();
        const target = camRect.top + camRect.height / 2;
        const rect = anchor.getBoundingClientRect();
        const actual = rect.top + rect.height / 2;
        const delta = target - actual;
        if (Math.abs(delta) < 1) break;
        // 探测每单位 ty 在屏幕上造成的 Y 位移
        gsap.set(cameraRig, { rotateX: fAngle, scale: fScale, y: ty + 20, force3D: true });
        const r2 = anchor.getBoundingClientRect();
        const a2 = r2.top + r2.height / 2;
        const dydty = (a2 - actual) / 20;
        if (Math.abs(dydty) < 0.01) break;
        ty += delta / dydty;
      }
      return ty;
    }

    // 按 section 在 rig 中的相对位置补偿透视缩放
    // rotateX 让顶部更远（视觉缩小）→ 放大补偿；底部已经偏大 → 不再下调（保持 F_SCALE 兜底）
    function getFocusScale(section: HTMLElement) {
      const rigH = cameraRig!.offsetHeight;
      if (!rigH) return F_SCALE;
      const focusY = getSectionFocusPoint(section);
      const rel = focusY / rigH;
      const alpha = 0.22; // 补偿幅度 — 越大顶部越放大
      return F_SCALE * Math.max(1, 1 + (0.5 - rel) * alpha);
    }

    // ---- 响应式参数 ----
    const isMobile = window.innerWidth < 768;
    const P_ANGLE = isMobile ? 22 : 25;        // 全景俯角
    const P_SCALE = isMobile ? 0.6 : 0.7;      // 全景缩放
    const F_ANGLE = isMobile ? 28 : 30;        // 聚焦俯角（更正面、文字可读）
    const F_SCALE = isMobile ? 1.4 : 1.7;      // 聚焦缩放（移动端收紧避免文字横向溢出）

    async function loadGSAP() {
      try {
        const { gsap } = await import('gsap');
        const { ScrollTrigger } = await import('gsap/ScrollTrigger');
        gsap.registerPlugin(ScrollTrigger);
        buildAnimation(gsap);
      } catch (e) {
        console.warn('GSAP 加载失败', e);
      }
    }
    loadGSAP();

    function buildAnimation(gsap: any) {
      if ((window as any).__shuttleST) (window as any).__shuttleST.kill();

      const shadow = shuttle.querySelector('.shuttle-shadow') as HTMLElement;
      const svgEl = shuttle.querySelector('.shuttle-svg') as HTMLElement;
      const spotlightEl = document.getElementById('spotlight');
      const vignetteEl = courtEl!.querySelector('.court-vignette') as HTMLElement;
      const contentSections = [rows.hero, rows.lessons, rows.knowledge, rows.cats, rows.footer].filter(Boolean);

      // ====== 段落定义 ======
      type FocusSeg = { type: 'focus'; section: HTMLElement; sx: number; dur: number; scale?: number };
      type TransSeg = { type: 'transition'; dur: number };
      type ExitSeg  = { type: 'exit'; dur: number };
      type Segment = FocusSeg | TransSeg | ExitSeg;

      const segs: Segment[] = [
        { type: 'focus',      section: rows.hero,      sx: 48, dur: 3.5 },
        { type: 'transition', dur: 3 },
        { type: 'focus',      section: rows.lessons,   sx: 56, dur: 3.5 },
        { type: 'transition', dur: 3 },
        { type: 'focus',      section: rows.knowledge, sx: 43, dur: 3.5 },
        { type: 'transition', dur: 3 },
        // Cats / Footer 的 anchor（court-pad-left）是半宽内容块，scale 太大会偏离视口中心
        // 桌面视口宽裕用 1.35；移动端用 1.1 让两半内容都能放得下
        { type: 'focus',      section: rows.cats,      sx: 50, dur: 3.5, scale: isMobile ? 1.1 : 1.35 },
        { type: 'transition', dur: 3 },
        { type: 'focus',      section: rows.footer,    sx: 30, dur: 3.5, scale: isMobile ? 1.1 : 1.35 },
        { type: 'exit',       dur: 1.5 },
      ];

      // ====== 初始状态 ======
      const heroY = centerY(rows.hero);
      const courtW = courtEl!.offsetWidth;
      function courtX(pct: number) { return courtW * pct / 100; }

      gsap.set(shuttle, { y: heroY, x: courtX(48), xPercent: -50, scale: 1, rotation: 0, force3D: true });
      gsap.set(svgEl, { opacity: 1 });
      gsap.set(shadow, { scaleX: 1, scaleY: 1, opacity: 0.2 });
      if (spotlightEl) gsap.set(spotlightEl, { y: heroY, x: courtX(48), xPercent: -50, yPercent: -50, opacity: 0.6, scale: 1, force3D: true });

      // 预计算每个聚焦段的校准后 ty（在变换后 anchor 视觉居中视口）
      const calibratedTy = new Map<HTMLElement, number>();
      for (const seg of segs) {
        if (seg.type === 'focus') {
          const fScale = seg.scale ?? getFocusScale(seg.section);
          calibratedTy.set(seg.section, calibrateFocusTy(seg.section, fScale, F_ANGLE, gsap));
        }
      }

      gsap.set(cameraRig, { rotateX: P_ANGLE, scale: P_SCALE, y: 0, force3D: true });
      shuttle.classList.add('is-active');

      // ====== 主时间线 ======
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: sceneEl,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1.3,
          invalidateOnRefresh: true,
        },
      });
      (window as any).__shuttleST = tl.scrollTrigger;

      // ====== 辅助：聚焦段 ======
      function addFocus(seg: FocusSeg, pos: number) {
        const { section, sx, dur } = seg;
        const ty = centerY(section);
        const oy = calibratedTy.get(section) ?? getSectionOffsetY(section);
        const fScale = seg.scale ?? getFocusScale(section);

        // 摄像机云台
        tl.to(cameraRig, { rotateX: F_ANGLE, scale: fScale, y: oy, duration: dur, ease: 'power3.inOut', force3D: true }, pos);

        // 球：降落
        tl.to(shuttle, { y: ty, x: courtX(sx), scale: 0.75, rotation: 0, duration: dur * 0.6, ease: 'power3.out', force3D: true }, pos);

        // 球光晕
        tl.to(svgEl, { opacity: 0.3, duration: dur * 0.5, ease: 'power2.out' }, pos);

        // 球影
        tl.to(shadow, { scaleX: 1, scaleY: 1, opacity: 0.35, duration: dur * 0.5, ease: 'power2.out' }, pos);

        // 聚光灯
        if (spotlightEl) tl.to(spotlightEl, { y: ty, x: courtX(sx), scale: 0.6, opacity: 0.95, duration: dur * 0.6, ease: 'power3.out', force3D: true }, pos);

        // 暗角
        if (vignetteEl) tl.to(vignetteEl, { opacity: 0.5, duration: dur * 0.4, ease: 'power2.out' }, pos);

        // 内容区 opacity
        contentSections.forEach(s => {
          tl.to(s, { opacity: s === section ? 1 : 0.15, duration: dur * 0.5, ease: 'power2.out' }, pos);
        });
      }

      // ====== 辅助：过渡段（抛物线飞行） ======
      function addTransition(
        dur: number, pos: number, transIdx: number,
        prevSec: HTMLElement | null, nextSec: HTMLElement,
        prevSx: number, nextSx: number
      ) {
        const prevY = prevSec ? centerY(prevSec) : heroY;
        const nextY = centerY(nextSec);
        const peakY = Math.min(prevY, nextY) - 120;   // 峰值抬高 120px
        const midSx = (prevSx + nextSx) / 2;
        const swing = 10;
        const midX = transIdx % 2 === 0 ? midSx - swing : midSx + swing;
        const peakRot = transIdx % 2 === 0 ? -10 : 10;

        tl.to(cameraRig, { rotateX: P_ANGLE, scale: P_SCALE, y: 0, duration: dur, ease: 'power2.inOut', force3D: true }, pos);

        // 上升：到达飞行峰值
        tl.to(shuttle, { y: peakY, x: courtX(midX), scale: 1.3, rotation: peakRot, duration: dur * 0.4, ease: 'power1.out', force3D: true }, pos);
        // 下降：落向下一站
        tl.to(shuttle, { y: nextY, x: courtX(nextSx), rotation: 0, duration: dur * 0.4, ease: 'power1.in', force3D: true }, pos + dur * 0.4);

        tl.to(svgEl, { opacity: 1, duration: dur * 0.4, ease: 'power2.out' }, pos);

        tl.to(shadow, { scaleX: 2, scaleY: 1.5, opacity: 0.08, duration: dur * 0.5, ease: 'power2.out' }, pos);

        // 聚光灯跟随球：上升到峰值，再下降到下一站
        if (spotlightEl) {
          tl.to(spotlightEl, { y: peakY, x: courtX(midX), scale: 1.6, opacity: 0.4, duration: dur * 0.4, ease: 'power1.out', force3D: true }, pos);
          tl.to(spotlightEl, { y: nextY, x: courtX(nextSx), duration: dur * 0.4, ease: 'power1.in', force3D: true }, pos + dur * 0.4);
        }

        if (vignetteEl) tl.to(vignetteEl, { opacity: 1, duration: dur * 0.5, ease: 'power2.out' }, pos);

        contentSections.forEach(s => {
          tl.to(s, { opacity: 0.12, duration: dur * 0.5, ease: 'power2.inOut' }, pos);
        });
      }

      // ====== 构建时间线 ======
      let prevSection: HTMLElement | null = null;
      let prevSx = 48;
      let transIdx = 0;

      for (let i = 0; i < segs.length; i++) {
        const seg = segs[i];
        const pos = tl.duration() || 0;

        if (seg.type === 'focus') {
          addFocus(seg, pos);
          prevSection = seg.section;
          prevSx = seg.sx;

        } else if (seg.type === 'transition') {
          const nextFocus = segs[i + 1];
          const nextSec = (nextFocus && nextFocus.type === 'focus')
            ? (nextFocus as FocusSeg).section : rows.footer;
          const nextSx = (nextFocus && nextFocus.type === 'focus')
            ? (nextFocus as FocusSeg).sx : 30;
          addTransition(seg.dur, pos, transIdx, prevSection, nextSec, prevSx, nextSx);
          transIdx++;

        } else if (seg.type === 'exit') {
          const dur = seg.dur;

          tl.to(cameraRig, { rotateX: P_ANGLE, scale: P_SCALE, y: 0, duration: dur, ease: 'power2.inOut', force3D: true }, pos);

          tl.to(shuttle, { opacity: 0, scale: 0.4, rotation: 20, duration: dur * 0.7, ease: 'power2.in' }, pos);

          if (spotlightEl) tl.to(spotlightEl, { opacity: 0, scale: 0.2, duration: dur * 0.7, ease: 'power2.in' }, pos);

          if (vignetteEl) tl.to(vignetteEl, { opacity: 0, duration: dur, ease: 'power2.out' }, pos);

          contentSections.forEach(s => {
            tl.to(s, { opacity: 1, duration: dur * 0.8, ease: 'power2.out' }, pos);
          });
        }
      }
    }
  })();
</script>
